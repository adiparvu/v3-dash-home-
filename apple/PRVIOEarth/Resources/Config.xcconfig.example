// PRVIO Earth — build configuration (copy to Config.xcconfig and fill in).
//
// Config.xcconfig is gitignored so secrets never land in source control.
// Note: `//` starts a comment in xcconfig, so escape it inside URLs as `/$()/`.

SUPABASE_URL = https:/$()/your-project-ref.supabase.co
SUPABASE_ANON_KEY = your-anon-or-publishable-key
API_BASE_URL = https:/$()/your-backend-deployment.example.com
