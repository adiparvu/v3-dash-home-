# Supabase — sign-in and backend persistence activate when these are set.
# Without them the app runs in the localStorage prototype mode.
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Used by backend services (e.g. immutable audit-log writes).
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web Push (notifications). The browser subscribes with the public key; the
# push-notify edge function signs deliveries with the matching private key.
# Generate a VAPID keypair with: npx web-push generate-vapid-keys
# The public key is browser-safe; set the private key + subject as edge-function
# secrets (VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY / VAPID_SUBJECT), never in the client.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# APNs (Apple Push) — required to push Live Activity updates to the native app.
# Token-based auth: create a .p8 key in the Apple Developer portal. APNS_AUTH_KEY
# holds the PEM contents of that .p8. Server-only secrets; never expose them.
# APNS_HOST defaults to https://api.push.apple.com (use the sandbox host in dev).
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apple-team-id
APNS_BUNDLE_ID=earth.prvio.app
# APNS_AUTH_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APNS_AUTH_KEY=your-apns-p8-pem-contents
APNS_HOST=https://api.push.apple.com
